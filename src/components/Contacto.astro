---
---
<section id="contacto" class="py-20 md:py-32 bg-[#050505] text-white px-6 border-t border-white/5 relative z-10">
  <div class="container mx-auto max-w-6xl relative z-20">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 md:gap-20 items-start">
      
      <div class="lg:col-span-7">
        <span class="text-gray-400 font-body font-bold tracking-[0.3em] uppercase text-[10px] md:text-xs mb-3 md:mb-4 block">Evaluación Sin Cargo</span>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold mb-6 tracking-tight leading-[1.1] text-white">
          Escribime hoy. <br/> <span class="italic font-light text-gray-400">Te respondo hoy.</span>
        </h2>
        <p class="text-base md:text-lg text-gray-400 font-light mb-8 md:mb-10 leading-relaxed md:leading-loose max-w-lg">
          Da el primer paso para proteger tus derechos. Escribime directo por WhatsApp para una atención inmediata o completá el formulario.
        </p>
        
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6 border-t border-white/10 pt-8 mt-8">
          
          <a href="https://wa.me/5491124551244" target="_blank" class="inline-flex items-center gap-4 md:gap-5 group">
            <div class="w-12 h-12 md:w-14 md:h-14 rounded-full border border-white/30 flex items-center justify-center text-white group-hover:bg-white group-hover:text-black transition-all duration-500 shadow-xl">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-whatsapp md:w-[22px] md:h-[22px]" viewBox="0 0 16 16"><path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"/></svg>
            </div>
            <div class="flex flex-col">
              <span class="font-body text-[9px] md:text-[10px] tracking-[0.2em] uppercase text-gray-500 mb-0.5 md:mb-1">WhatsApp Directo</span>
              <span class="font-bold text-white group-hover:text-gray-300 transition-colors text-sm md:text-base tracking-wide">11 2455-1244</span>
            </div>
          </a>
          
          <div class="hidden sm:block w-px h-10 bg-white/10"></div>
          
          <div class="inline-flex items-center gap-4 md:gap-5">
            <div class="w-12 h-12 md:w-14 md:h-14 rounded-full border border-white/10 flex items-center justify-center text-gray-400 bg-white/5">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
            </div>
            <div class="flex flex-col">
              <span class="font-body text-[9px] md:text-[10px] tracking-[0.2em] uppercase text-gray-500 mb-0.5 md:mb-1">Nuestro Estudio</span>
              <span class="font-light text-white text-xs md:text-sm tracking-wide leading-tight">Mariano Moreno 253<br/><span class="text-gray-400 text-[10px]">Temperley, Buenos Aires</span></span>
            </div>
          </div>
          
        </div>
      </div>

      <div class="lg:col-span-5 w-full">
        <div class="bg-[#111] p-6 md:p-10 border border-white/20 shadow-2xl relative rounded-sm">
          <div class="absolute top-0 left-0 w-full h-1 bg-white"></div>
          
          <form id="form-contacto" class="space-y-6 md:space-y-8 mt-2">
            
            <div class="relative group">
              <label for="nombre" class="block text-[9px] md:text-[10px] font-body tracking-[0.2em] uppercase text-gray-500 group-focus-within:text-white mb-1 md:mb-2 transition-colors">Nombre completo</label>
              <input type="text" id="nombre" name="nombre" placeholder="Tu nombre" pattern="^[a-zA-ZÀ-ÿ\s]+$" title="Solo se permiten letras y espacios" class="w-full bg-transparent border-b border-white/10 pb-2 md:pb-3 text-white text-sm md:text-base focus:outline-none focus:border-white transition-colors font-light placeholder:text-gray-700" required>
            </div>
            
            <div class="relative group">
              <label for="tipo" class="block text-[9px] md:text-[10px] font-body tracking-[0.2em] uppercase text-gray-500 group-focus-within:text-white mb-1 md:mb-2 transition-colors">Tipo de consulta</label>
              <div class="relative">
                <select id="tipo" name="tipo" class="w-full bg-transparent border-b border-white/10 pb-2 md:pb-3 text-white text-sm md:text-base focus:outline-none focus:border-white transition-colors font-light appearance-none cursor-pointer" required>
                  <option value="" disabled selected class="text-gray-500 bg-[#111]">Seleccioná un área...</option>
                  <option value="Sucesiones y Familia" class="text-white bg-[#111]">Sucesiones y Familia</option>
                  <option value="Accidentes de Tránsito" class="text-white bg-[#111]">Accidentes de Tránsito</option>
                  <option value="Laboral y ART" class="text-white bg-[#111]">Laboral y ART</option>
                  <option value="Civil y Comercial" class="text-white bg-[#111]">Civil y Comercial</option>
                  <option value="Otra consulta" class="text-white bg-[#111]">Otra consulta</option>
                </select>
                <div class="absolute right-0 top-1/2 -translate-y-1/2 pointer-events-none text-gray-500">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" /></svg>
                </div>
              </div>
            </div>
            
            <div class="relative group">
              <label for="consulta" class="block text-[9px] md:text-[10px] font-body tracking-[0.2em] uppercase text-gray-500 group-focus-within:text-white mb-1 md:mb-2 transition-colors">Motivo de consulta</label>
              <textarea id="consulta" name="consulta" rows="3" placeholder="Contanos brevemente qué sucedió..." class="w-full bg-transparent border-b border-white/10 pb-2 md:pb-3 text-white text-sm md:text-base focus:outline-none focus:border-white transition-colors font-light resize-none placeholder:text-gray-700" required></textarea>
            </div>
            
            <button type="submit" class="w-full bg-white text-black hover:bg-gray-200 py-4 font-body font-bold uppercase tracking-[0.2em] text-[10px] md:text-[11px] transition-all duration-500 mt-2 rounded-sm">
              Enviar Mensaje
            </button>
          </form>
        </div>
      </div>

    </div>

    <div class="mt-16 md:mt-24 w-full h-[400px] md:h-[450px] bg-[#111] border border-white/10 relative overflow-hidden rounded-sm group">
      <div class="absolute top-0 left-0 w-full h-1 bg-white z-10 opacity-50 group-hover:opacity-100 transition-opacity duration-500"></div>
      
      <iframe 
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3277.940428383213!2d-58.3995574!3d-34.7696238!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95bccd159187ecf5%3A0xe5a3bb4062a4ebf5!2sMariano%20Moreno%20253%2C%20B1834AEJ%20Temperley%2C%20Provincia%20de%20Buenos%20Aires!5e0!3m2!1ses-419!2sar!4v1700000000000!5m2!1ses-419!2sar" 
        class="w-full h-full filter invert grayscale contrast-125 opacity-70 group-hover:opacity-100 transition-all duration-700 pointer-events-auto"
        style="border:0;" 
        allowfullscreen="" 
        loading="lazy" 
        referrerpolicy="no-referrer-when-downgrade">
      </iframe>
      
      <div class="absolute bottom-6 left-6 bg-[#050505]/90 backdrop-blur-md border border-white/20 p-5 pointer-events-none hidden md:block rounded-sm shadow-2xl">
         <span class="block text-white font-heading font-bold text-lg tracking-wide">Dr. Sebastián Penas</span>
         <span class="block text-gray-400 font-body text-[10px] uppercase tracking-widest mt-1.5">Mariano Moreno 253, Temperley</span>
      </div>
    </div>

  </div>
</section>

<script>
  const formContacto = document.getElementById('form-contacto');
  const nombreInput = document.getElementById('nombre') as HTMLInputElement;

  // Evita que escriban números en tiempo real
  if (nombreInput) {
    nombreInput.addEventListener('input', function(e) {
      this.value = this.value.replace(/[0-9!@#\$%\^\&*\)\(+=._-]/g, '');
    });
  }
  
  if (formContacto) {
    formContacto.addEventListener('submit', function(e) {
      e.preventDefault(); 
      
      const nombre = nombreInput.value.trim();
      const tipo = (document.getElementById('tipo') as HTMLSelectElement).value;
      const consulta = (document.getElementById('consulta') as HTMLTextAreaElement).value.trim();
      
      // Armamos el mensaje final con el tipo de reclamo
      const mensaje = `Hola Dr. Penas, me contacto desde su sitio web.%0A%0A*Nombre:* ${nombre}%0A*Área de consulta:* ${tipo}%0A*Mensaje:* ${consulta}`;
      
      const numeroDestino = "5491124551244";
      const urlWhatsApp = `https://wa.me/${numeroDestino}?text=${mensaje}`;
      
      window.open(urlWhatsApp, '_blank');
      
      (formContacto as HTMLFormElement).reset();
    });
  }
</script>