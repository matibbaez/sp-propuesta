---
// src/components/Hero.astro
---

<section id="inicio" class="relative pt-32 pb-20 lg:pt-40 lg:pb-32 overflow-hidden bg-gradient-to-br from-pool-light via-pool-medium to-pool-light">
    
    <div class="container mx-auto px-6 relative z-10">
        <div class="flex flex-col-reverse lg:flex-row items-center gap-12">
            
            <div class="lg:w-1/2 text-center lg:text-left space-y-6">
                <span class="inline-block px-4 py-2 rounded-full bg-brand/10 text-brand font-semibold text-sm tracking-wider">
                    NEUQUÉN
                </span>
                <h2 class="text-4xl lg:text-5xl font-bold text-brand-dark leading-tight">
                    Tognonato & Asociadas <br> Estudio Jurídico
                </h2>
                <p class="text-xl text-text-muted">
                    Servicio jurídico integral, cercano y profesional.
                </p>
                
                <div class="flex items-center justify-center lg:justify-start gap-4 pt-4">
                    <div class="flex items-center gap-2 text-brand font-semibold">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1.323l3.954 1.582 1.599-.8a1 1 0 011.394 1.173l-1.583 7.915a1 1 0 01-.746.786L11.5 16.635V19a1 1 0 11-2 0v-2.365l-3.118-1.556a1 1 0 01-.746-.786L4.053 6.278a1 1 0 011.394-1.173l1.599.8L10 4.323V3a1 1 0 011-1zm-5 8.274l-.818 4.09 2.818 1.41V10.274zm10 0v1.41l2.818-1.41-.818-4.09zM9 12.204v3.832l-3.877-1.939.38-1.893H9zm2 0h3.497l.38 1.893L11 16.036v-3.832z" clip-rule="evenodd" />
                        </svg>
                        <span>Victoria Tognonato, Abogada</span>
                    </div>
                </div>

                <div class="pt-8">
                    <a href="#contacto" class="inline-block bg-brand text-white px-8 py-3 rounded-md font-semibold hover:bg-brand-dark transition-colors shadow-lg shadow-brand/20">
                        Solicitar Consulta
                    </a>
                </div>
            </div>

            <div class="lg:w-1/2 relative">
                 <svg class="absolute top-0 right-0 text-brand/10 h-64 w-64 -translate-y-12 translate-x-12" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zm-2.625 6c-.54 0-.828.419-.936.634a1.96 1.96 0 00-.189.866c0 .298.059.605.189.866.108.215.396.634.936.634.54 0 .828-.419.936-.634.13-.26.189-.568.189-.866 0-.298-.059-.605-.189-.866-.108-.215-.396-.634-.936-.634zm4.314.634c.108-.215.396-.634.936-.634.54 0 .828.419.936.634.13.26.189.568.189.866 0 .298-.059.605-.189.866-.108.215-.396.634-.936.634-.54 0-.828-.419-.936-.634a1.96 1.96 0 00-.189-.866c0-.298.059-.605.189-.866zm2.023 6.828a.75.75 0 10-1.06-1.06 3.75 3.75 0 01-5.304 0 .75.75 0 00-1.06 1.06 5.25 5.25 0 007.424 0z" clip-rule="evenodd" />
                  </svg>
                  
                <img src="https://placehold.co/600x700/2E7D75/FFFFFF/png?text=Foto+Victoria+Tognonato" alt="Victoria Tognonato" class="relative z-10 rounded-lg shadow-2xl mx-auto lg:ml-auto max-h-[500px] object-cover border-4 border-white">
            </div>
        </div>
    </div>

    <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none rotate-180">
        <svg class="relative block w-[calc(100%+1.3px)] h-[60px] text-white" data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
            <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" fill="currentColor"></path>
        </svg>
    </div>
</section>