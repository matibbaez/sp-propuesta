---
// src/components/Services.astro

const services = [
  {
    title: "Sucesiones",
    desc: "Acompañamiento integral en procesos sucesorios, garantizando la correcta transmisión de bienes.",
    icon: "M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" // Icono de persona/familia
  },
  {
    title: "Divorcios",
    desc: "Gestión de divorcios y cuestiones de familia con un enfoque humano y resolutivo.",
    icon: "M13.5 10.5V6.75a4.5 4.5 0 119 0v3.75M3.75 21.75h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H3.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" // Icono de candado/separación (simbólico)
  },
  {
    title: "División de Bienes",
    desc: "Asesoramiento experto para una partición justa y equitativa del patrimonio.",
    icon: "M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" // Icono de bienes/casa
  },
  {
    title: "Homologación de Acuerdos",
    desc: "Validación judicial de acuerdos privados para brindarles fuerza legal y ejecutoria.",
    icon: "M10.125 2.25h-4.5c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125v-9M10.125 2.25h.375a9 9 0 019 9v.375M10.125 2.25A3.375 3.375 0 0113.5 5.625v1.5c0 .621.504 1.125 1.125 1.125h1.5a3.375 3.375 0 013.375 3.375M9 15l2.25 2.25L15 12" // Icono de contrato firmado
  },
  {
    title: "Reclamos ART",
    desc: "Defensa de los derechos del trabajador ante accidentes laborales y enfermedades profesionales.",
    icon: "M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" // Icono de estrella/protección (simbólico)
  }
];
---

<section id="servicios" class="py-24 bg-white">
    <div class="container mx-auto px-6">
        <div class="text-center mb-16">
            <h2 class="text-3xl lg:text-4xl font-bold text-brand-dark uppercase tracking-wider">Nuestros Servicios</h2>
            <div class="w-24 h-1 bg-brand mx-auto mt-4 rounded-full"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {services.map((service) => (
                <div class="group bg-pool-light/30 border border-pool-medium/50 rounded-xl p-8 hover:shadow-xl hover:border-brand/30 transition-all duration-300 hover:-translate-y-1">
                    <div class="w-16 h-16 bg-brand/10 text-brand rounded-lg flex items-center justify-center mb-6 group-hover:bg-brand group-hover:text-white transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
                            <path stroke-linecap="round" stroke-linejoin="round" d={service.icon} />
                        </svg>  
                    </div>
                    <h3 class="text-xl font-bold text-brand-dark mb-3">{service.title}</h3>
                    <p class="text-text-muted leading-relaxed">{service.desc}</p>
                </div>
            ))}
        </div>
    </div>
</section>