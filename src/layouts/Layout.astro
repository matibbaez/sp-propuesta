---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { 
  title, 
  description = "Estudio Jurídico Dr. Sebastián Penas | Asesoramiento Jurídico Integral: Familia, Sucesiones, Laboral, ART, Accidentes, Civil y Comercial."
} = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body class="antialiased flex flex-col min-h-screen selection:bg-black selection:text-white">
    
    <header id="main-header" class="fixed w-full top-0 z-50 bg-transparent border-b border-transparent transition-all duration-500 py-6">
      <div class="container mx-auto px-6 md:px-10 flex justify-between items-center">
        
        <a href="#inicio" id="logo-link" class="flex items-center gap-3 md:gap-4 group z-50 pt-1 text-white transition-colors duration-500">
          
          <div id="logo-svg" class="w-10 h-10 md:w-12 md:h-12 flex-shrink-0 transition-all duration-700 group-hover:scale-105 text-white">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L12 22"></path>
              <path d="M12 6L4 6"></path>
              <path d="M12 6L20 6"></path>
              <path d="M4 6L2 13C2 13 3 15 4 15C5 15 6 13 6 13L4 6"></path>
              <path d="M20 6L18 13C18 13 19 15 20 15C21 15 22 13 22 13L20 6"></path>
              <path d="M9 22L15 22"></path>
            </svg>
          </div>

          <div class="flex flex-col justify-center">
            <h1 class="text-xl md:text-2xl font-heading font-bold leading-none tracking-widest uppercase">
              <span id="logo-accent" class="font-bold transition-colors duration-500 text-white">SP</span> ABOGADO
            </h1>
            <span id="logo-sub" class="text-[7px] md:text-[8px] font-body tracking-[0.2em] uppercase font-bold mt-1.5 transition-colors duration-500 text-gray-300">Dr. Sebastián Penas</span>
          </div>
        </a>
        
        <div class="hidden lg:flex items-center gap-10">
          <nav>
            <ul id="nav-links" class="flex items-center gap-10 text-[11px] font-body font-semibold tracking-[0.2em] text-white transition-colors duration-500 uppercase">
              <li>
                <a href="#areas" class="flex items-center gap-2 group hover:text-gray-300 transition-colors duration-500">
                  <span class="w-1.5 h-1.5 rounded-full bg-white opacity-0 group-hover:opacity-100 transition-opacity duration-500"></span>
                  Áreas de Práctica
                </a>
              </li>
              <li>
                <a href="#estudio" class="flex items-center gap-2 group hover:text-gray-300 transition-colors duration-500">
                  <span class="w-1.5 h-1.5 rounded-full bg-white opacity-0 group-hover:opacity-100 transition-opacity duration-500"></span>
                  La Firma
                </a>
              </li>
            </ul>
          </nav>
      
          <div id="nav-divider" class="w-px h-8 bg-white/20 transition-colors duration-500"></div>
          <a id="nav-btn" href="#contacto" class="inline-flex items-center justify-center border border-white text-white px-8 py-3.5 font-body font-bold text-[10px] uppercase tracking-[0.25em] hover:bg-white hover:text-black transition-all duration-500 rounded-sm">
            Evaluar mi caso
          </a>
        </div>

        <button id="mobile-menu-btn" class="lg:hidden z-50 relative focus:outline-none w-10 h-10 flex flex-col justify-center items-end gap-[6px] group overflow-hidden" aria-label="Abrir Menú">
          <span class="w-7 h-[2px] bg-white transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] origin-center" id="line1"></span>
          <span class="w-5 h-[2px] bg-white transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] origin-center group-hover:w-7" id="line2"></span>
          <span class="w-7 h-[2px] bg-white transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] origin-center" id="line3"></span>
        </button>
      </div>
    </header>

    <div id="mobile-menu" class="fixed inset-0 bg-[#050505]/98 backdrop-blur-2xl opacity-0 pointer-events-none transition-opacity duration-500 z-45 flex flex-col pt-36 pb-12 overflow-y-auto">
      <div class="container mx-auto px-8 w-full flex flex-col h-full grow">
        <nav class="flex flex-col gap-8 w-full mt-4">
          <a href="#areas" class="mobile-link group flex items-center gap-6 border-b border-white/10 pb-6 translate-y-8 opacity-0 transition-all duration-500 delay-100">
            <span class="text-gray-500 font-body text-xs tracking-widest opacity-80">01</span>
            <span class="text-3xl font-heading font-light text-white group-hover:text-gray-300 transition-colors">Especialidades</span>
          </a>
          <a href="#estudio" class="mobile-link group flex items-center gap-6 border-b border-white/10 pb-6 translate-y-8 opacity-0 transition-all duration-500 delay-200">
            <span class="text-gray-500 font-body text-xs tracking-widest opacity-80">02</span>
            <span class="text-3xl font-heading font-light text-white group-hover:text-gray-300 transition-colors">La Firma</span>
          </a>
          <a href="#contacto" class="mobile-link group flex items-center gap-6 border-b border-white/10 pb-6 translate-y-8 opacity-0 transition-all duration-500 delay-300">
            <span class="text-gray-500 font-body text-xs tracking-widest opacity-80">03</span>
            <span class="text-3xl font-heading font-light text-white group-hover:text-gray-300 transition-colors">Contacto</span>
          </a>
        </nav>
      </div>
    </div>

    <main class="grow">
      <slot />
    </main>

    <footer class="bg-[#050505] text-gray-400 pt-24 pb-8 border-t border-white/5 relative z-20 overflow-hidden">
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-white/5 rounded-full blur-[150px] pointer-events-none -translate-y-1/2 translate-x-1/3"></div>
      <div class="container mx-auto px-6 md:px-10 grid grid-cols-1 md:grid-cols-12 gap-16 lg:gap-12 mb-20 relative z-10">
        
        <div class="md:col-span-12 lg:col-span-5 pr-0 lg:pr-12">
          <a href="#inicio" class="flex items-center gap-4 mb-6 group inline-flex">
            <div class="w-10 h-10 text-white group-hover:scale-105 transition-transform duration-500">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2L12 22"></path>
                <path d="M12 6L4 6"></path>
                <path d="M12 6L20 6"></path>
                <path d="M4 6L2 13C2 13 3 15 4 15C5 15 6 13 6 13L4 6"></path>
                <path d="M20 6L18 13C18 13 19 15 20 15C21 15 22 13 22 13L20 6"></path>
                <path d="M9 22L15 22"></path>
              </svg>
            </div>
            <div class="flex flex-col justify-center pt-1">
              <h2 class="text-2xl font-heading font-bold text-white leading-none tracking-widest uppercase">
                <span class="text-white">SP</span> ABOGADO
              </h2>
            </div>
          </a>
          <p class="text-sm font-light leading-loose text-gray-400 mb-6 max-w-sm">
            Te brindo soluciones legales con la seriedad y empatía que tu caso exige. Asesoramiento jurídico integral en todo el país.
          </p>
          
          <div class="flex items-start gap-3 mb-8">
            <div class="mt-1 flex-shrink-0 text-white">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
            </div>
            <p class="text-xs font-body tracking-[0.1em] text-gray-400 uppercase leading-relaxed">
              Mariano Moreno 253, B1834AEJ<br/>
              <span class="text-gray-500">Temperley, Buenos Aires</span>
            </p>
          </div>

          <a href="#contacto" class="inline-flex items-center gap-3 text-white hover:text-gray-300 transition-colors font-body text-[11px] tracking-widest uppercase font-bold">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path d="M3 4a2 2 0 00-2 2v1.161l8.441 4.221a1.25 1.25 0 001.118 0L19 7.162V6a2 2 0 00-2-2H3z" /><path d="M19 8.839l-7.77 3.885a2.75 2.75 0 01-2.46 0L1 8.839V14a2 2 0 002 2h14a2 2 0 002-2V8.839z" /></svg>
            Consultas Online
          </a>

          <div class="flex items-center gap-3 mt-8 pt-8 border-t border-white/5">
            <span class="text-[9px] uppercase tracking-[0.2em] font-bold text-gray-500 mr-2">Seguime en</span>
            
            <a href="https://www.tiktok.com/@Spabogado" target="_blank" class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-gray-400 hover:bg-white hover:text-black hover:border-white transition-all duration-500 shadow-sm bg-white/5 group">
              <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="w-3.5 h-3.5 group-hover:scale-110 transition-transform" viewBox="0 0 16 16"><path d="M9 0h1.98c.144.715.54 1.617 1.235 2.512C12.895 3.389 13.797 4 15 4v2c-1.753 0-3.07-.814-4-1.829V11a5 5 0 1 1-5-5v2a3 3 0 1 0 3 3z"/></svg>
            </a>
            
            <a href="https://www.instagram.com/sebastianpenasabogado/" target="_blank" class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-gray-400 hover:bg-white hover:text-black hover:border-white transition-all duration-500 shadow-sm bg-white/5 group">
              <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="w-3.5 h-3.5 group-hover:scale-110 transition-transform" viewBox="0 0 16 16"><path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.917 3.917 0 0 0-1.417.923A3.927 3.927 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.916 3.916 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.926 3.926 0 0 0-.923-1.417A3.911 3.911 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0h.003zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.035 1.204.166 1.486.275.373.145.64.319.92.599.28.28.453.546.598.92.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.47 2.47 0 0 1-.599.919c-.28.28-.546.453-.92.598-.281.11-.705.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.478 2.478 0 0 1-.92-.598 2.48 2.48 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233 0-2.136.008-2.388.046-3.231.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92.28-.28.546-.453.92-.598.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045v.002zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92zm-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217zm0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334z"/></svg>
            </a>
          </div>
          
        </div>

        <div class="md:col-span-6 lg:col-span-3">
          <span class="text-white uppercase tracking-[0.2em] text-[10px] font-bold mb-8 flex items-center gap-3"><span class="w-3 h-px bg-white"></span> Práctica Legal</span>
          <ul class="space-y-4 text-sm font-light text-gray-400">
            <li><a href="#areas" class="hover:text-white transition-colors flex items-center gap-3 group"><span class="w-1.5 h-1.5 rounded-full bg-gray-600 group-hover:bg-white transition-colors"></span> Familia y Sucesiones</a></li>
            <li><a href="#areas" class="hover:text-white transition-colors flex items-center gap-3 group"><span class="w-1.5 h-1.5 rounded-full bg-gray-600 group-hover:bg-white transition-colors"></span> Laboral y ART</a></li>
            <li><a href="#areas" class="hover:text-white transition-colors flex items-center gap-3 group"><span class="w-1.5 h-1.5 rounded-full bg-gray-600 group-hover:bg-white transition-colors"></span> Accidentes de Tránsito</a></li>
            <li><a href="#areas" class="hover:text-white transition-colors flex items-center gap-3 group"><span class="w-1.5 h-1.5 rounded-full bg-gray-600 group-hover:bg-white transition-colors"></span> Civil y Comercial</a></li>
          </ul>
        </div>

        <div class="md:col-span-6 lg:col-span-4">
          <span class="text-white uppercase tracking-[0.2em] text-[10px] font-bold mb-8 flex items-center gap-3"><span class="w-3 h-px bg-white"></span> Atención Rápida</span>
          <div class="bg-white/5 border border-white/20 p-6 relative group hover:border-white/50 transition-colors duration-500 rounded-sm">
            <div class="absolute top-0 left-0 w-1 h-full bg-white"></div>
            <ul class="space-y-2 text-sm font-light text-gray-400">
              <li class="text-white font-medium text-base flex items-center gap-3 mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-white"><path fill-rule="evenodd" d="M2 3.5A1.5 1.5 0 013.5 2h1.148a1.5 1.5 0 011.465 1.175l.716 3.223a1.5 1.5 0 01-1.052 1.767l-.933.267c-.41.117-.643.555-.48.95a11.542 11.542 0 006.254 6.254c.395.163.833-.07.95-.48l.267-.933a1.5 1.5 0 011.767-1.052l3.223.716A1.5 1.5 0 0118 15.352V16.5a1.5 1.5 0 01-1.5 1.5H15c-1.149 0-2.263-.15-3.326-.43A13.022 13.022 0 012.43 8.326 13.019 13.019 0 012 5V3.5z" clip-rule="evenodd" /></svg>
                Canal Directo
              </li>
              <li class="pl-8 font-bold text-white tracking-widest text-[10px] uppercase">Escribime</li>
              <li class="pl-8 text-xs pt-1">11 2455-1244</li>
            </ul>
          </div>
        </div>

      </div>
      <div class="container mx-auto px-6 md:px-10 pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6 text-[9px] uppercase tracking-[0.2em] font-body text-gray-500 font-medium">
        <p>© {new Date().getFullYear()} Estudio Jurídico Dr. Sebastián Penas. Todos los derechos reservados.</p>
        <div class="flex items-center gap-2"><span>Diseño y Desarrollo por</span><a href="https://www.wearevisionpath.com/es" class="text-white hover:text-gray-300 transition-colors font-bold">VisionPath</a></div>
      </div>
    </footer>

    <a href="https://wa.me/5491124551244" target="_blank" aria-label="Contactar por WhatsApp" class="fixed bottom-6 right-6 md:bottom-8 md:right-8 z-50 bg-[#25D366] text-white p-4 rounded-full shadow-2xl hover:scale-105 hover:bg-white hover:text-[#25D366] transition-all duration-500 flex items-center justify-center border border-white/10">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-whatsapp relative z-10" viewBox="0 0 16 16"><path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"/></svg>
    </a>

    <script>
      import Lenis from 'lenis';
      const lenis = new Lenis({ duration: 1.5, easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
      function raf(time: number) { lenis.raf(time); requestAnimationFrame(raf); }
      requestAnimationFrame(raf);

      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      const header = document.getElementById('main-header');
      const mobileLinks = document.querySelectorAll('.mobile-link');
      
      const logoLink = document.getElementById('logo-link');
      const logoAccent = document.getElementById('logo-accent');
      const logoSub = document.getElementById('logo-sub');
      const logoSvg = document.getElementById('logo-svg');
      const navLinks = document.getElementById('nav-links');
      const navDivider = document.getElementById('nav-divider');
      const navBtn = document.getElementById('nav-btn');
      const line1 = document.getElementById('line1');
      const line2 = document.getElementById('line2');
      const line3 = document.getElementById('line3');

      let isScrolled = false;
      let isMenuOpen = false;

      const closeMenu = () => {
        isMenuOpen = false;
        menu?.classList.remove('opacity-100', 'pointer-events-auto');
        menu?.classList.add('opacity-0', 'pointer-events-none');
        
        const targetLineColor = isScrolled ? 'bg-[#050505]' : 'bg-white';
        line1?.classList.replace('bg-white', targetLineColor);
        line3?.classList.replace('bg-white', targetLineColor);
        
        line1?.classList.remove('rotate-45', 'translate-y-[8px]');
        line2?.classList.remove('opacity-0', 'translate-x-4');
        line3?.classList.remove('-rotate-45', '-translate-y-[8px]');
        
        mobileLinks.forEach(link => {
          link.classList.remove('translate-y-0', 'opacity-100');
          link.classList.add('translate-y-8', 'opacity-0');
        });

        if (isScrolled) {
            header?.classList.replace('bg-transparent', 'bg-white/95');
            header?.classList.replace('border-transparent', 'border-gray-100');
            header?.classList.add('backdrop-blur-xl', 'shadow-sm');
            
            logoLink?.classList.replace('text-white', 'text-[#050505]');
            logoSvg?.classList.replace('text-white', 'text-[#050505]');
            logoAccent?.classList.replace('text-white', 'text-[#050505]');
        }
        lenis.start();
      };

      const openMenu = () => {
        isMenuOpen = true;
        menu?.classList.remove('opacity-0', 'pointer-events-none');
        menu?.classList.add('opacity-100', 'pointer-events-auto');
        
        const currentLineColor = isScrolled ? 'bg-[#050505]' : 'bg-white';
        line1?.classList.replace(currentLineColor, 'bg-white');
        line3?.classList.replace(currentLineColor, 'bg-white');
        
        line1?.classList.add('rotate-45', 'translate-y-[8px]');
        line2?.classList.add('opacity-0', 'translate-x-4');
        line3?.classList.add('-rotate-45', '-translate-y-[8px]');
        
        mobileLinks.forEach(link => {
          link.classList.remove('translate-y-8', 'opacity-0');
          link.classList.add('translate-y-0', 'opacity-100');
        });

        if (isScrolled) {
            header?.classList.replace('bg-white/95', 'bg-transparent');
            header?.classList.replace('border-gray-100', 'border-transparent');
            header?.classList.remove('backdrop-blur-xl', 'shadow-sm');
            
            logoLink?.classList.replace('text-[#050505]', 'text-white');
            logoSvg?.classList.replace('text-[#050505]', 'text-white');
            logoAccent?.classList.replace('text-[#050505]', 'text-white');
        }
        lenis.stop();
      };

      btn?.addEventListener('click', () => isMenuOpen ? closeMenu() : openMenu());

      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', (e) => {
          e.preventDefault();
          const target = e.currentTarget as HTMLElement;
          const targetId = target.getAttribute('href');
          if (!targetId || targetId === '#') return;
          const targetElement = document.querySelector(targetId) as HTMLElement;
          
          if (targetElement) {
            if (target.classList.contains('mobile-link') || target.closest('#mobile-menu')) {
              closeMenu();
              setTimeout(() => lenis.scrollTo(targetElement, { offset: -100, duration: 2 }), 300);
            } else {
              lenis.scrollTo(targetElement, { offset: -100, duration: 2 });
            }
          }
        });
      });

      lenis.on('scroll', (e: any) => {
        if (!isMenuOpen) {
          if (e.scroll > 50 && !isScrolled) {
            isScrolled = true;
            header?.classList.replace('bg-transparent', 'bg-white/95');
            header?.classList.replace('border-transparent', 'border-gray-100');
            header?.classList.add('backdrop-blur-xl', 'shadow-sm');
            header?.classList.replace('py-6', 'py-4');

            logoLink?.classList.replace('text-white', 'text-[#050505]');
            logoSvg?.classList.replace('text-white', 'text-[#050505]');
            logoAccent?.classList.replace('text-white', 'text-[#050505]');
            logoSub?.classList.replace('text-gray-300', 'text-gray-500');

            navLinks?.classList.replace('text-white', 'text-[#050505]');
            navDivider?.classList.replace('bg-white/20', 'bg-gray-200');

            navBtn?.classList.replace('border-white', 'border-[#050505]');
            navBtn?.classList.replace('text-white', 'text-[#050505]');
            navBtn?.classList.replace('hover:bg-white', 'hover:bg-[#050505]');
            navBtn?.classList.replace('hover:text-black', 'hover:text-white');

            line1?.classList.replace('bg-white', 'bg-[#050505]');
            line2?.classList.replace('bg-white', 'bg-[#050505]');
            line3?.classList.replace('bg-white', 'bg-[#050505]');
            
          } else if (e.scroll <= 50 && isScrolled) {
            isScrolled = false;
            header?.classList.replace('bg-white/95', 'bg-transparent');
            header?.classList.replace('border-gray-100', 'border-transparent');
            header?.classList.remove('backdrop-blur-xl', 'shadow-sm');
            header?.classList.replace('py-4', 'py-6');

            logoLink?.classList.replace('text-[#050505]', 'text-white');
            logoSvg?.classList.replace('text-[#050505]', 'text-white');
            logoAccent?.classList.replace('text-[#050505]', 'text-white');
            logoSub?.classList.replace('text-gray-500', 'text-gray-300');

            navLinks?.classList.replace('text-[#050505]', 'text-white');
            navDivider?.classList.replace('bg-gray-200', 'bg-white/20');

            navBtn?.classList.replace('border-[#050505]', 'border-white');
            navBtn?.classList.replace('text-[#050505]', 'text-white');
            navBtn?.classList.replace('hover:bg-[#050505]', 'hover:bg-white');
            navBtn?.classList.replace('hover:text-white', 'hover:text-black');

            line1?.classList.replace('bg-[#050505]', 'bg-white');
            line2?.classList.replace('bg-[#050505]', 'bg-white');
            line3?.classList.replace('bg-[#050505]', 'bg-white');
          }
        }
      });
    </script>
  </body>
</html>