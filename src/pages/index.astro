---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Estudio Jurídico Dr. Sebastián Penas | Asesoramiento Integral">
  
  <section id="inicio" class="relative bg-[#050505] text-white min-h-[90vh] md:min-h-screen flex items-center px-6 md:px-12 overflow-hidden pt-32 md:pt-40 pb-20 md:pb-24 border-b border-white/5">

    <div class="absolute inset-0 z-0 opacity-[0.03] bg-[url('https://www.transparenttextures.com/patterns/noise-pattern-with-subtle-cross-lines.png')]"></div>
    <div class="absolute top-0 right-0 w-[40rem] md:w-[60rem] h-[40rem] md:h-[60rem] bg-white/5 rounded-full blur-[100px] md:blur-[140px] pointer-events-none z-0 -translate-y-1/3 translate-x-1/3"></div>

    <div class="container mx-auto max-w-6xl relative z-10 w-full flex flex-col items-start justify-center">

      <div class="flex flex-wrap items-center gap-3 md:gap-4 mb-8 md:mb-10">
        <a href="#testimonios" class="inline-flex items-center gap-2 bg-white/5 border border-white/10 rounded-full px-4 py-2 backdrop-blur-md hover:bg-white/10 hover:border-white/50 transition-colors cursor-pointer group">
          <div class="flex text-white text-[8px] md:text-[10px] tracking-[0.1em] group-hover:scale-105 transition-transform">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          </div>
          <span class="text-white font-body text-[9px] md:text-[10px] tracking-[0.1em] uppercase font-bold">
            5.0 Google Reviews (48)
          </span>
        </a>
      </div>

      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-heading font-bold leading-[1.1] md:leading-[1.05] mb-8 text-white tracking-tight max-w-4xl relative z-10">
        Dr. Sebastián Penas <br />
        <span class="italic font-light text-gray-400 relative inline-block">
          La solidez que tu caso exige.
        </span>
      </h1>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 w-full mt-2 md:mt-4">
        
        <div class="lg:col-span-6 relative">
          <div class="absolute left-0 top-2 w-1 h-full max-h-16 bg-gradient-to-b from-white to-transparent hidden md:block"></div>
          <p class="text-base md:text-xl font-light text-gray-300 leading-relaxed md:pl-6 max-w-xl relative z-10">
            Con base en Temperley y actuación en toda la Provincia de Buenos Aires, garantizamos un acompañamiento legal estructurado en <span class="text-white font-medium">Familia, Sucesiones, Laboral, ART, Accidentes, Civil, Comercial y Penal.</span>
          </p>
        </div>

        <div class="lg:col-span-6 flex flex-col sm:flex-row items-center lg:justify-end gap-4 md:gap-6 w-full relative z-10">
          <a href="#contacto" class="relative group inline-flex items-center justify-center w-full sm:w-auto overflow-hidden bg-white px-8 py-5 md:px-10 md:py-6 font-body font-bold uppercase tracking-[0.2em] text-[10px] md:text-[11px] text-black transition-all duration-500 shadow-[0_0_20px_rgba(255,255,255,0.1)] hover:shadow-[0_0_30px_rgba(255,255,255,0.3)] rounded-sm">
            <span class="absolute w-0 h-0 transition-all duration-500 ease-out bg-gray-200 rounded-full group-hover:w-72 group-hover:h-56"></span>
            <span class="relative flex items-center gap-3 text-black">
              Consultar mi caso
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 transform group-hover:translate-x-1 transition-transform"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </span>
          </a>
          
          <a href="#areas" class="inline-flex items-center justify-center gap-4 text-white hover:text-gray-300 transition-colors duration-300 font-body font-bold text-[10px] md:text-[11px] uppercase tracking-[0.2em] px-6 py-5 md:py-6 w-full sm:w-auto border border-white/20 hover:border-white/50 bg-white/5 backdrop-blur-sm group rounded-sm">
            Ver Especialidades
            <span class="w-0 h-px bg-white transition-all duration-300 group-hover:w-4 hidden sm:block"></span>
          </a>
        </div>

      </div>

    </div>
  </section>

  <section id="el-doctor" class="py-20 md:py-32 bg-white relative z-10 border-b border-gray-200 overflow-hidden">
    <div class="container mx-auto px-6 md:px-10 max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 md:gap-20 items-center">
        
        <div class="lg:col-span-5 relative group order-2 lg:order-1">
          <div class="absolute -inset-4 bg-[#F4F4F5] transform -rotate-2 rounded-sm transition-transform duration-700 group-hover:-rotate-1"></div>
          
          <div class="relative aspect-[4/5] overflow-hidden rounded-sm bg-gray-200">
            <img 
              src="https://images.unsplash.com/photo-1560250097-0b93528c311a?q=80&w=800&auto=format&fit=crop" 
              alt="Dr. Sebastián Penas" 
              class="object-cover w-full h-full filter grayscale contrast-125 group-hover:scale-105 transition-transform duration-1000"
            />
          </div>
          
          <div class="absolute -bottom-6 -right-2 md:-right-8 bg-black text-white p-6 md:p-8 shadow-2xl hidden sm:block rounded-sm">
            <span class="block font-heading font-bold text-3xl md:text-4xl mb-1 leading-none">15<span class="text-gray-400 font-light">+</span></span>
            <span class="block font-body text-[9px] tracking-[0.2em] uppercase text-gray-400 mt-2">Años de Exp.</span>
          </div>
        </div>

        <div class="lg:col-span-7 flex flex-col justify-center order-1 lg:order-2">
          <span class="inline-flex items-center gap-3 text-black font-body font-bold tracking-[0.3em] uppercase text-[10px] md:text-xs mb-5 md:mb-6">
            <span class="w-8 h-px bg-black"></span>
            Dirección General
          </span>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-black tracking-tight leading-[1.1] mb-6">
            Dr. Sebastián Penas
          </h2>
          
          <p class="text-xl md:text-2xl font-heading italic text-gray-500 mb-8 leading-relaxed">
            "El derecho no se trata solo de leyes, se trata de personas, de su patrimonio y de su tranquilidad. Nuestro enfoque es 100% estratégico, transparente y humano."
          </p>
          
          <div class="space-y-6 text-base md:text-lg text-gray-600 font-light leading-relaxed mb-10 max-w-2xl">
            <p>
              Con base en Temperley y ejercicio ininterrumpido en los tribunales de la Provincia de Buenos Aires, el Dr. Penas lidera un equipo enfocado en la resolución ágil y efectiva de conflictos legales complejos.
            </p>
            <p>
              Su práctica profesional se caracteriza por hablarle claro al cliente desde el día uno, realizando un análisis jurídico minucioso y aplicando una capacidad de negociación orientada a evitar litigios innecesarios, o ganarlos con firmeza cuando son inevitables.
            </p>
          </div>
          
          <div class="flex items-center gap-6 pt-6 border-t border-gray-200">
            <div class="flex flex-col">
              <span class="font-body font-bold text-[9px] uppercase tracking-widest text-black">Matrícula Provincial</span>
              <span class="text-gray-500 text-[10px] md:text-[11px] tracking-widest mt-1">T° XX F° XXX C.A.L.Z.</span>
            </div>
            <div class="w-px h-8 bg-gray-200"></div>
            <div class="flex flex-col">
              <span class="font-body font-bold text-[9px] uppercase tracking-widest text-black">Colegio de Abogados</span>
              <span class="text-gray-500 text-[10px] md:text-[11px] tracking-widest mt-1">Lomas de Zamora</span>
            </div>
          </div>
          
        </div>

      </div>
    </div>
  </section>

  <section class="py-20 md:py-32 bg-[#F4F4F5] px-6 relative z-10 border-b border-gray-200">
    
    <div class="container mx-auto max-w-6xl">
      
      <div class="text-center mb-12 md:mb-20">
        <span class="text-gray-500 font-body font-bold tracking-[0.3em] uppercase text-[10px] md:text-xs mb-3 md:mb-4 block">Entendemos tu situación</span>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-black tracking-tight leading-[1.1]">
          ¿Qué conflicto legal necesitás <br class="md:hidden"/> resolver hoy?
        </h2>
        <p class="text-gray-500 font-light mt-6 text-base md:text-lg max-w-2xl mx-auto leading-relaxed">
          Nuestra prioridad es brindarte un panorama claro y definir la estrategia legal más directa desde el primer encuentro.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        
        <div class="bg-white p-8 md:p-10 relative group hover:-translate-y-1 transition-all duration-500 border border-gray-200 hover:border-black shadow-sm overflow-hidden flex flex-col h-full rounded-sm">
          <div class="absolute top-0 left-0 w-1 h-0 bg-black transition-all duration-500 group-hover:h-full"></div>
          <div class="absolute -bottom-4 -right-4 text-[100px] md:text-[130px] font-heading font-bold text-gray-100 group-hover:text-gray-200 transition-colors duration-500 pointer-events-none select-none leading-none">01</div>
          
          <div class="relative z-10 flex-grow">
            <span class="text-[9px] md:text-[10px] font-body tracking-[0.2em] uppercase text-gray-500 font-bold mb-4 block">Sucesiones y Familia</span>
            <h3 class="text-xl md:text-2xl font-heading font-bold text-black mb-4 leading-tight">
              Proteger tu futuro y el de los tuyos.
            </h3>
            <p class="font-light text-gray-500 text-sm md:text-base leading-relaxed">
              Agilizamos transmisiones de bienes, declaratorias de herederos, divorcios y fijación de alimentos para asegurar tu tranquilidad.
            </p>
          </div>
          
          <div class="mt-8 pt-6 border-t border-gray-100 relative z-10">
            <a href="#contacto" class="inline-flex items-center gap-2 text-[10px] md:text-xs font-body font-bold uppercase tracking-[0.2em] text-black hover:text-gray-500 transition-colors">
              Iniciar Trámite <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 transform group-hover:translate-x-1.5 transition-transform duration-300"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>
        </div>

        <div class="bg-white p-8 md:p-10 relative group hover:-translate-y-1 transition-all duration-500 border border-gray-200 hover:border-black shadow-sm overflow-hidden flex flex-col h-full rounded-sm">
          <div class="absolute top-0 left-0 w-1 h-0 bg-black transition-all duration-500 group-hover:h-full"></div>
          <div class="absolute -bottom-4 -right-4 text-[100px] md:text-[130px] font-heading font-bold text-gray-100 group-hover:text-gray-200 transition-colors duration-500 pointer-events-none select-none leading-none">02</div>
          
          <div class="relative z-10 flex-grow">
            <span class="text-[9px] md:text-[10px] font-body tracking-[0.2em] uppercase text-gray-500 font-bold mb-4 block">Laboral y Accidentes</span>
            <h3 class="text-xl md:text-2xl font-heading font-bold text-black mb-4 leading-tight">
              Hacer valer lo que te corresponde.
            </h3>
            <p class="font-light text-gray-500 text-sm md:text-base leading-relaxed">
              Exigimos tu indemnización frente a despidos, irregularidades, accidentes de trabajo (ART) o siniestros de tránsito con Aseguradoras.
            </p>
          </div>
          
          <div class="mt-8 pt-6 border-t border-gray-100 relative z-10">
            <a href="#contacto" class="inline-flex items-center gap-2 text-[10px] md:text-xs font-body font-bold uppercase tracking-[0.2em] text-black hover:text-gray-500 transition-colors">
              Reclamar Ahora <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 transform group-hover:translate-x-1.5 transition-transform duration-300"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>
        </div>

        <div class="bg-white p-8 md:p-10 relative group hover:-translate-y-1 transition-all duration-500 border border-gray-200 hover:border-black shadow-sm overflow-hidden flex flex-col h-full rounded-sm">
          <div class="absolute top-0 left-0 w-1 h-0 bg-black transition-all duration-500 group-hover:h-full"></div>
          <div class="absolute -bottom-4 -right-4 text-[100px] md:text-[130px] font-heading font-bold text-gray-100 group-hover:text-gray-200 transition-colors duration-500 pointer-events-none select-none leading-none">03</div>
          
          <div class="relative z-10 flex-grow">
            <span class="text-[9px] md:text-[10px] font-body tracking-[0.2em] uppercase text-gray-500 font-bold mb-4 block">Civil, Comercial y Penal</span>
            <h3 class="text-xl md:text-2xl font-heading font-bold text-black mb-4 leading-tight">
              Estrategia robusta ante contingencias.
            </h3>
            <p class="font-light text-gray-500 text-sm md:text-base leading-relaxed">
              Litigios de daños, cumplimiento de contratos, conflictos mercantiles y sólidas defensas o querellas en el ámbito penal.
            </p>
          </div>
          
          <div class="mt-8 pt-6 border-t border-gray-100 relative z-10">
            <a href="#contacto" class="inline-flex items-center gap-2 text-[10px] md:text-xs font-body font-bold uppercase tracking-[0.2em] text-black hover:text-gray-500 transition-colors">
              Solicitar Defensa <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 transform group-hover:translate-x-1.5 transition-transform duration-300"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section id="areas" class="py-20 md:py-32 bg-white px-6 relative z-10">
    <div class="container mx-auto max-w-6xl">
      
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 md:mb-20 gap-6 md:gap-8">
        <div>
          <span class="text-gray-500 font-body font-bold tracking-[0.3em] uppercase text-[10px] md:text-xs mb-3 md:mb-4 block">Práctica Legal</span>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-black tracking-tight leading-[1.1]">Dominio en cada área.</h2>
        </div>
        <p class="text-base md:text-lg text-gray-500 font-light leading-relaxed md:leading-loose max-w-sm md:text-right border-l-2 md:border-l-0 md:border-r-2 border-black pl-4 md:pl-0 md:pr-4">
          Defendemos tus intereses con la máxima exigencia técnica y un trato personalizado continuo en todas las instancias.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        
        <div class="lg:col-span-2 relative bg-[#050505] p-8 md:p-12 border border-white/10 overflow-hidden group transition-all duration-500 hover:-translate-y-1 shadow-2xl shadow-black/20 rounded-sm">
          <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full blur-[80px] pointer-events-none group-hover:bg-white/10 transition-colors duration-500"></div>
          <div class="absolute -bottom-6 -right-2 text-[100px] md:text-[140px] font-heading font-bold text-white/5 transition-colors duration-500 pointer-events-none select-none leading-none">01</div>
          
          <div class="relative z-10 flex flex-col h-full">
            <div>
              <div class="inline-flex items-center gap-2 mb-4">
                <span class="w-2 h-2 rounded-full bg-white animate-pulse"></span>
                <span class="text-[10px] md:text-[11px] font-body font-bold text-gray-300 uppercase tracking-widest block">Derecho Privado</span>
              </div>
              
              <h3 class="text-2xl md:text-4xl font-heading font-bold text-white mb-6 leading-tight">Familia, Sucesiones<br/> y Civil</h3>
              
              <ul class="space-y-4 text-sm md:text-base font-medium text-gray-400 mb-10">
                <li class="flex items-start gap-3">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 md:w-5 md:h-5 text-white shrink-0"><path fill-rule="evenodd" d="M16.403 12.652a3 3 0 000-5.304 3 3 0 00-3.75-3.751 3 3 0 00-5.305 0 3 3 0 00-3.751 3.75 3 3 0 000 5.305 3 3 0 003.75 3.751 3 3 0 005.305 0 3 3 0 003.751-3.75zm-2.546-4.46a.75.75 0 00-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                  <span class="text-white font-bold tracking-wide">Resolución de expedientes sucesorios con celeridad.</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 md:w-5 md:h-5 text-white shrink-0"><path fill-rule="evenodd" d="M16.403 12.652a3 3 0 000-5.304 3 3 0 00-3.75-3.751 3 3 0 00-5.305 0 3 3 0 00-3.751 3.75 3 3 0 000 5.305 3 3 0 003.75 3.751 3 3 0 005.305 0 3 3 0 003.751-3.75zm-2.546-4.46a.75.75 0 00-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                  <span>Divorcios, cuota alimentaria y régimen de comunicación.</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 md:w-5 md:h-5 text-white shrink-0"><path fill-rule="evenodd" d="M16.403 12.652a3 3 0 000-5.304 3 3 0 00-3.75-3.751 3 3 0 00-5.305 0 3 3 0 00-3.751 3.75 3 3 0 000 5.305 3 3 0 003.75 3.751 3 3 0 005.305 0 3 3 0 003.751-3.75zm-2.546-4.46a.75.75 0 00-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                  <span>Daños, perjuicios y redacción de contratos.</span>
                </li>
              </ul>
            </div>
            <div class="mt-auto pt-6 border-t border-white/10">
              <a href="#contacto" class="inline-flex items-center gap-2 text-[10px] md:text-xs font-body font-bold uppercase tracking-[0.2em] text-white hover:text-gray-400 transition-colors">
                Consultar Área Civil <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 transform group-hover:translate-x-1.5 transition-transform duration-300"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </a>
            </div>
          </div>
        </div>

        <div class="relative bg-[#F4F4F5] p-8 md:p-10 border border-gray-200 overflow-hidden group transition-all duration-500 hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.05)] hover:-translate-y-1 rounded-sm">
          <div class="absolute top-0 left-0 w-0 h-1 bg-black transition-all duration-500 group-hover:w-full"></div>
